<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F2F2F7">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Safety Analytics"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1C1C1E"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/countUnsafe"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:gravity="center"
            android:text="0\nUnsafe"
            android:textSize="14sp"
            android:textColor="#FF3B30"
            android:background="@drawable/bg_report_type_card"/>

        <TextView
            android:id="@+id/countSus"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:gravity="center"
            android:text="0\nSuspicious"
            android:textSize="14sp"
            android:textColor="#FF9500"
            android:background="@drawable/bg_report_type_card"/>

        <TextView
            android:id="@+id/countEmergency"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="0\nEmergency"
            android:textSize="14sp"
            android:textColor="#E91E63"
            android:background="@drawable/bg_report_type_card"/>

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Active heatmap zones"
        android:textSize="14sp"
        android:textColor="#8E8E93"
        android:layout_marginBottom="8dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvHeatZones"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>
