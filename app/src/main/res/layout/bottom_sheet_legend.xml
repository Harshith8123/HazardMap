<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:paddingTop="12dp"
    android:paddingBottom="20dp"
    android:elevation="8dp">

    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="12dp"
        android:background="#E5E5EA"/>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="All"
                android:checked="true"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipUnsafe"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="Unsafe area"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSusBehavior"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="Sus behavior"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSusActivity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Suspicious activity"/>

        </LinearLayout>
    </HorizontalScrollView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hold on map to drop a report pin"
        android:textSize="12sp"
        android:textColor="#8E8E93"
        android:gravity="center"
        android:layout_marginTop="8dp"/>

</LinearLayout>
